#!/bin/sh
# jumpstart — symlink jumpstarter/.devcontainer/ directory into the current repo.
#   cd <target-repo> && jumpstart
set -eu

repo_root=$(cd -P "$(dirname "$0")/.." && pwd)
src=$repo_root/.devcontainer
[ -d "$src" ] || { echo "not found: $src" >&2; exit 1; }

link=$PWD/.devcontainer

if [ -e "$link" ] || [ -L "$link" ]; then
  echo "$link already exists; remove it first" >&2
  exit 1
fi

set -x
ln -s "$src" "$link"
